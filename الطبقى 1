/*
 * Layer: 1 (HAL/Bootstrap) - Main Entry Point
 * Purpose: تجميع واختبار كل مكونات الطبقة الأولى
 * Status: [ ] Testing [ ] Pass [ ] Failed
 * Dependencies: memory, vga, serial, idt, pic
 */

#include <kprintf.h>
#include <memory.h>
#include <idt.h>
#include <multiboot2.h>

void kernel_main(uint32_t magic, struct multiboot_info *mboot)
{
    // Early initialization
    kprintf_init();
    
    kprintf("🚀 Madar OS - Layer 1 Starting...\n");
    kprintf("  Multiboot Magic: 0x%x\n", magic);
    
    // Initialize subsystems
    memory_init((uint64_t)mboot);
    idt_init();
    pic_init();
    
    // Run integration tests
    test_memory_allocator();
    test_kprintf();
    test_interrupt_system();
    
    // Final status
    kprintf("✅ Layer 1: All systems operational\n");
    kprintf("🎯 Ready for Layer 2 (Kernel Core)\n");
    
    // Enable interrupts
    asm volatile("sti");
    
    // Idle loop
    while (1) {
        asm volatile("hlt");
    }
}
```

