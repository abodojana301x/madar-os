/*
 * Layer: 1 (HAL/Bootstrap)
 * Purpose: إدارة الذاكرة الفيزيائية البسيطة
 * Constraints: لا يدعم virtual memory في هذه المرحلة
 * Dependencies: multiboot2.h
 */

#ifndef MEMORY_H
#define MEMORY_H

#include <types.h>

#define PAGE_SIZE 4096
#define MAX_MEMORY_REGIONS 32

typedef struct {
    uint64_t base;
    uint64_t length;
    uint32_t type;  // 1 = usable, others = reserved
} memory_region_t;

typedef struct {
    uint64_t total_memory;
    uint64_t usable_memory;
    uint64_t next_free_page;
    uint64_t total_pages;
    uint64_t free_pages;
} memory_map_t;

// Function prototypes
void memory_init(uint64_t multiboot_info_ptr);
uint64_t pmm_alloc_page(void);
void pmm_free_page(uint64_t addr);
void memory_print_info(void);

// Test function
void test_memory_allocator(void);

#endif
```

**memory.c:**
```c
/*
 * Layer: 1 (HAL/Bootstrap)
 * Purpose: تنفيذ إدارة الذاكرة الفيزيائية
 * Status: [ ] Testing [ ] Pass [ ] Failed
 */

#include "memory.h"
#include <multiboot2.h>
#include <compiler.h>

static memory_map_t mem_map = {0};
static memory_region_t regions[MAX_MEMORY_REGIONS];
static uint32_t num_regions = 0;

static uint8_t *page_bitmap = NULL;
static uint64_t bitmap_size = 0;

void memory_init(uint64_t multiboot_ptr)
{
    struct multiboot_info *mboot = (struct multiboot_info *)multiboot_ptr;
    
    // Parse memory map from Multiboot2
    // ... (implementation details)
    
    mem_map.total_memory = 0;
    mem_map.usable_memory = 0;
    
    for (uint32_t i = 0; i < num_regions; i++) {
        mem_map.total_memory += regions[i].length;
        if (regions[i].type == 1) {
            mem_map.usable_memory += regions[i].length;
        }
    }
    
    mem_map.total_pages = mem_map.usable_memory / PAGE_SIZE;
    mem_map.free_pages = mem_map.total_pages;
    mem_map.next_free_page = 0x100000; // Start after 1MB
    
    // Initialize page bitmap
    bitmap_size = (mem_map.total_pages + 7) / 8;
    page_bitmap = (uint8_t *)0x200000; // Reserve memory for bitmap
    
    // Clear bitmap (all pages free)
    for (uint64_t i = 0; i < bitmap_size; i++) {
        page_bitmap[i] = 0;
    }
}

uint64_t pmm_alloc_page(void)
{
    // Simple bitmap allocator
    for (uint64_t i = 0; i < mem_map.total_pages; i++) {
        uint64_t byte_idx = i / 8;
        uint8_t bit_idx = i % 8;
        
        if (!(page_bitmap[byte_idx] & (1 << bit_idx))) {
            // Page is free, mark as used
            page_bitmap[byte_idx] |= (1 << bit_idx);
            mem_map.free_pages--;
            
            uint64_t addr = 0x100000 + (i * PAGE_SIZE);
            return addr;
        }
    }
    
    // No free pages
    return 0;
}

void pmm_free_page(uint64_t addr)
{
    uint64_t page_idx = (addr - 0x100000) / PAGE_SIZE;
    uint64_t byte_idx = page_idx / 8;
    uint8_t bit_idx = page_idx % 8;
    
    page_bitmap[byte_idx] &= ~(1 << bit_idx);
    mem_map.free_pages++;
}

void memory_print_info(void)
{
    kprintf("📊 Memory Info:\n");
    kprintf("  Total: %llu MB\n", mem_map.total_memory / (1024 * 1024));
    kprintf("  Usable: %llu MB\n", mem_map.usable_memory / (1024 * 1024));
    kprintf("  Pages: %llu total, %llu free\n", 
            mem_map.total_pages, mem_map.free_pages);
}

void test_memory_allocator(void)
{
    kprintf("🧪 Testing memory allocator...\n");
    
    uint64_t test_pages[10];
    uint64_t allocated = 0;
    
    // Allocate 10 pages
    for (int i = 0; i < 10; i++) {
        test_pages[i] = pmm_alloc_page();
        if (test_pages[i] != 0) {
            allocated++;
            // Write test pattern
            uint64_t *ptr = (uint64_t *)test_pages[i];
            *ptr = 0xDEADBEEFCAFEBABE;
        }
    }
    
    // Verify
    uint64_t verified = 0;
    for (int i = 0; i < 10; i++) {
        if (test_pages[i] != 0) {
            uint64_t *ptr = (uint64_t *)test_pages[i];
            if (*ptr == 0xDEADBEEFCAFEBABE) {
                verified++;
            }
            pmm_free_page(test_pages[i]);
        }
    }
    
    if (allocated == 10 && verified == 10) {
        kprintf("✅ Memory allocator test PASSED\n");
    } else {
        kprintf("❌ Memory allocator test FAILED: alloc=%llu, verify=%llu\n", 
                allocated, verified);
    }
}
```

