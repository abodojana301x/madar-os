#### 🔧 **التفاصيل التقنية:**
**linker.ld:**
```ld
/* 
 * Layer: 1 (HAL/Bootstrap)
 * Purpose: تحديد خريطة الذاكرة للنواة
 * Constraints: لا يتجاوز 50KB في هذه المرحلة
 */

ENTRY(boot_start)

SECTIONS
{
    . = 1M;

    .boot :
    {
        __boot_start = .;
        *(.boot)
        __boot_end = .;
    }

    .text :
    {
        __text_start = .;
        *(.text)
        __text_end = .;
    }

    .rodata :
    {
        __rodata_start = .;
        *(.rodata)
        __rodata_end = .;
    }

    .data :
    {
        __data_start = .;
        *(.data)
        __data_end = .;
    }

    .bss :
    {
        __bss_start = .;
        *(.bss)
        *(COMMON)
        __bss_end = .;
    }

    __kernel_end = .;
}
```

**Makefile:**
```makefile
# Layer: 1 Build System
# Purpose: تجميع النواة بأمان واختبارها

CC = x86_64-elf-gcc
AS = x86_64-elf-as
LD = x86_64-elf-ld

CFLAGS = -ffreestanding -fno-stack-protector -fno-pic \
         -mno-red-zone -mgeneral-regs-only \
         -Wall -Wextra -Werror -std=gnu11 \
         -Iinclude

ASFLAGS = -g

LDFLAGS = -T linker.ld -nostdlib

SRCS = kernel/boot.s kernel/main.c
OBJS = $(SRCS:.c=.o)
OBJS = $(OBJS:.s=.o)

TARGET = kernel.bin

.PHONY: all clean run debug test

all: $(TARGET)

$(TARGET): $(OBJS)
	@echo "🔗 Linking $(TARGET)..."
	$(LD) $(LDFLAGS) -o $@ $^
	@echo "✅ Build complete. Size: $$(stat -c%s $(TARGET)) bytes"

%.o: %.c
	@echo "📝 Compiling $<..."
	$(CC) $(CFLAGS) -c $< -o $@

%.o: %.s
	@echo "🔧 Assembling $<..."
	$(AS) $(ASFLAGS) $< -o $@

clean:
	rm -f $(OBJS) $(TARGET) kernel.elf

run: $(TARGET)
	qemu-system-x86_64 -kernel $(TARGET) -serial stdio -monitor stdio

debug: $(TARGET)
	qemu-system-x86_64 -kernel $(TARGET) -s -S -serial stdio

test: $(TARGET)
	@echo "🧪 Running basic tests..."
	@size $(TARGET) | awk '/^Total/ {if ($$2 < 51200) print "✅ Size OK (<50KB)"; else {print "❌ Size too large"; exit 1}}'
	@echo "✅ All build tests passed"
```

